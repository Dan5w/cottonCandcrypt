# Credenciales de la base de datos MySQL (catálogo de backups)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=backups0

# Rutas a binarios de MySQL
MYSQLDUMP_PATH=C:\Program Files\MySQL\MySQL Server 9.2\bin\mysqldump.exe
MYSQL_PATH=C:\Program Files\MySQL\MySQL Server 9.2\bin\mysql.exe

# Clave secreta de Flask (cambiar en producción)
FLASK_SECRET_KEY=dbvault-secret-key-2024-change-in-production
